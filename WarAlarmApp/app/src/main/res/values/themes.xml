<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for WarAlarm - Dark Mode -->
    <style name="Theme.WarAlarm" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/red_500</item>
        <item name="colorPrimaryVariant">@color/red_600</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/slate_950</item>
        <item name="colorSurface">@color/slate_900</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:statusBarColor">@color/slate_950</item>
        <item name="android:navigationBarColor">@color/slate_950</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- No ActionBar variant -->
    <style name="Theme.WarAlarm.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash screen -->
    <style name="Theme.WarAlarm.Splash" parent="Theme.WarAlarm.NoActionBar">
        <item name="android:windowBackground">@color/slate_950</item>
    </style>

    <!-- AlertDialog theme matching dark UI -->
    <style name="Theme.WarAlarm.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/slate_900</item>
        <item name="colorPrimary">@color/red_500</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/slate_300</item>
        <item name="colorControlActivated">@color/orange_500</item>
        <item name="colorControlNormal">@color/slate_400</item>
        <item name="buttonBarPositiveButtonStyle">@style/WarAlarm.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/WarAlarm.Dialog.Button</item>
    </style>

    <style name="WarAlarm.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/red_500</item>
    </style>

    <!-- Card style -->
    <style name="WarAlarm.Card" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Button Primary -->
    <style name="WarAlarm.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Button Secondary -->
    <style name="WarAlarm.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/slate_300</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Input Field -->
    <style name="WarAlarm.Input" parent="">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/slate_400</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="WarAlarm.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/slate_950</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>
