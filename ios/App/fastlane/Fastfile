default_platform(:ios)

platform :ios do
  desc "Build and upload to App Store Connect"
  lane :release do
    # Setup CI keychain
    setup_ci

    # Install Apple WWDR intermediate certificates for trust chain
    # Without these, imported distribution certs won't be recognized as valid signing identities
    sh("curl -sO https://www.apple.com/certificateauthority/AppleWWDRCAG3.cer")
    sh("curl -sO https://www.apple.com/certificateauthority/AppleWWDRCAG6.cer")
    sh("security import AppleWWDRCAG3.cer -k ~/Library/Keychains/fastlane_tmp_keychain -T /usr/bin/codesign -T /usr/bin/security || true")
    sh("security import AppleWWDRCAG6.cer -k ~/Library/Keychains/fastlane_tmp_keychain -T /usr/bin/codesign -T /usr/bin/security || true")
    sh("rm -f AppleWWDRCAG3.cer AppleWWDRCAG6.cer")

    # Setup API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      in_house: false
    )

    # Auto-create/download distribution certificate
    get_certificates(
      api_key: api_key,
      platform: "ios"
    )

    # Auto-create/download provisioning profile
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.warrescue.appname",
      platform: "ios"
    )

    # Configure manual code signing with the downloaded cert and profile
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "App.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: "com.warrescue.appname"
    )

    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.warrescue.appname" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    # Upload to App Store Connect
    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Build only (no upload)"
  lane :build_only do
    # Setup CI keychain
    setup_ci

    # Install Apple WWDR intermediate certificates for trust chain
    sh("curl -sO https://www.apple.com/certificateauthority/AppleWWDRCAG3.cer")
    sh("curl -sO https://www.apple.com/certificateauthority/AppleWWDRCAG6.cer")
    sh("security import AppleWWDRCAG3.cer -k ~/Library/Keychains/fastlane_tmp_keychain -T /usr/bin/codesign -T /usr/bin/security || true")
    sh("security import AppleWWDRCAG6.cer -k ~/Library/Keychains/fastlane_tmp_keychain -T /usr/bin/codesign -T /usr/bin/security || true")
    sh("rm -f AppleWWDRCAG3.cer AppleWWDRCAG6.cer")

    # Setup API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      in_house: false
    )

    # Auto-create/download distribution certificate
    get_certificates(
      api_key: api_key,
      platform: "ios"
    )

    # Auto-create/download provisioning profile
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.warrescue.appname",
      platform: "ios"
    )

    # Configure manual code signing with the downloaded cert and profile
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "App.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: "com.warrescue.appname"
    )

    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.warrescue.appname" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )
  end
end
