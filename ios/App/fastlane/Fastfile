default_platform(:ios)

platform :ios do
  # Revoke orphaned distribution certificates whose private keys were lost in previous CI runs
  private_lane :revoke_orphaned_certs do |options|
    require 'spaceship'

    api_key = options[:api_key]

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      filepath: ENV["API_KEY_PATH"]
    )
    Spaceship::ConnectAPI.token = token

    all_certs = []
    # Check both legacy (IOS_DISTRIBUTION) and modern (DISTRIBUTION / Apple Distribution) types
    ["DISTRIBUTION", "IOS_DISTRIBUTION"].each do |cert_type|
      found = Spaceship::ConnectAPI::Certificate.all(
        filter: { certificateType: cert_type }
      )
      UI.message("Found #{found.count} certificate(s) of type #{cert_type}")
      all_certs.concat(found)
    end

    UI.message("Total distribution certificates: #{all_certs.count}")

    if all_certs.count >= 2
      UI.important("Maximum certificates reached, revoking all orphaned certificates...")
      all_certs.each do |cert|
        UI.message("Revoking certificate: #{cert.id} (#{cert.display_name})")
        cert.delete!
      end
      UI.success("Revoked #{all_certs.count} orphaned certificate(s)")
    end
  end

  # Enable the Push Notifications capability on the App ID via the App Store Connect API,
  # so the auto-generated provisioning profile carries aps-environment (required since native push was added).
  private_lane :ensure_push_capability do
    require 'spaceship'

    token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      filepath: ENV["API_KEY_PATH"]
    )
    Spaceship::ConnectAPI.token = token

    bundle_id = "com.warrescue.appname"
    bid = Spaceship::ConnectAPI::BundleId.all(filter: { identifier: bundle_id }).find { |b| b.identifier == bundle_id }
    UI.user_error!("在 Apple Developer 找不到 App ID #{bundle_id}，请先在 Identifiers 里注册该 Bundle ID") if bid.nil?

    begin
      bid.create_capability("PUSH_NOTIFICATIONS")
      UI.success("✅ 已为 #{bundle_id} 启用 Push Notifications 能力")
    rescue => e
      # 若该能力已启用，Apple 会返回 409/duplicate，可安全忽略；其它错误打印出来便于排查
      UI.important("启用 Push 能力返回：#{e.message}（若提示已存在/duplicate 可忽略）")
    end
  end

  desc "Build and upload to App Store Connect"
  lane :release do
    keychain_path = ENV["KEYCHAIN_PATH"]
    keychain_password = ENV["KEYCHAIN_PASSWORD"]

    # Setup API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      in_house: false
    )

    # Revoke orphaned certificates from previous CI runs (private keys were lost)
    revoke_orphaned_certs(api_key: api_key)

    # Ensure the App ID has Push Notifications capability (app entitlements require aps-environment)
    ensure_push_capability

    # Auto-create/download distribution certificate
    get_certificates(
      api_key: api_key,
      platform: "ios",
      keychain_path: keychain_path,
      keychain_password: keychain_password
    )

    # Re-apply partition list after cert import (critical for codesign access)
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '#{keychain_password}' '#{keychain_path}'")

    # Debug: verify signing identity is available
    sh("security find-identity -v -p codesigning '#{keychain_path}'")

    # Auto-create/download provisioning profile (force refresh to match new cert)
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.warrescue.appname",
      platform: "ios",
      force: true
    )

    # Configure manual code signing with the downloaded cert and profile
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "App.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: "com.warrescue.appname",
      targets: ["App"]
    )

    # Auto-increment build number to avoid upload conflicts
    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.warrescue.appname"
      ) + 1,
      xcodeproj: "App.xcodeproj"
    )

    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.warrescue.appname" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )

    # 上传二进制到 App Store Connect（走 TestFlight / 构建列表通道）。
    # 不用 upload_to_app_store：它会尝试“创建/校验 App Store 版本”，而当前 1.1 正在审核（版本被锁），
    # 会报 “You cannot create a new version of the App in the current state / version number has been previously used”。
    # upload_to_testflight(pilot) 只上传二进制、不碰版本号，规避该冲突；版本与提交改在 App Store Connect 网页手动操作。
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build only (no upload)"
  lane :build_only do
    keychain_path = ENV["KEYCHAIN_PATH"]
    keychain_password = ENV["KEYCHAIN_PASSWORD"]

    # Setup API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["API_KEY_PATH"],
      in_house: false
    )

    # Revoke orphaned certificates from previous CI runs
    revoke_orphaned_certs(api_key: api_key)

    # Ensure the App ID has Push Notifications capability (app entitlements require aps-environment)
    ensure_push_capability

    # Auto-create/download distribution certificate
    get_certificates(
      api_key: api_key,
      platform: "ios",
      keychain_path: keychain_path,
      keychain_password: keychain_password
    )

    # Re-apply partition list after cert import
    sh("security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '#{keychain_password}' '#{keychain_path}'")

    # Auto-create/download provisioning profile (force refresh to match new cert)
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.warrescue.appname",
      platform: "ios",
      force: true
    )

    # Configure manual code signing with the downloaded cert and profile
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      path: "App.xcodeproj",
      code_sign_identity: "Apple Distribution",
      profile_name: lane_context[SharedValues::SIGH_NAME],
      bundle_identifier: "com.warrescue.appname",
      targets: ["App"]
    )

    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.warrescue.appname" => lane_context[SharedValues::SIGH_NAME]
        }
      }
    )
  end
end
