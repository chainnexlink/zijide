# Google Maps JavaScript API Key（在线地图/路线/导航用）
GOOGLE_MAPS_KEY=your_google_maps_key_here

# 离线地图瓦片源（可选）。
# 留空 = 用免费 OSM 公共瓦片（默认，已可用，适合起步/中小用量）。
# 规模化后改用"允许离线缓存"的授权服务商，填其瓦片模板（{z}/{x}/{y} 占位原样保留）即可，代码无需改：
#   例: MAP_TILE_URL=https://api.maptiler.com/maps/streets-v2/{z}/{x}/{y}.png?key=YOUR_KEY
# MAP_TILE_URL=
